{
  "name": "scheduler-app",
  "version": "1.0.0",
  "description": "Desktop scheduler mock-up for PM OS commands via Cursor ACP",
  "main": "src/main.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --mac"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {},
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.ccpmos.scheduler",
    "productName": "CCPM Scheduler",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../commands",
        "to": "commands",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  }
}
